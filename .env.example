# Chave de API da Groq (obrigatória)
GROQ_API_KEY=sua_chave_groq_aqui

# Modelo para transcrição (Whisper)
# Modelos disponíveis: whisper-large-v3-turbo, whisper-large-v3, distil-whisper-large-v3-en, etc.
TRANSCRIPTION_MODEL=whisper-large-v3

# Modelo para a limpeza/correção ortográfica da transcrição
# Modelos recomendados: llama-3.1-8b-instant, llama3-8b-8192
CLEANUP_MODEL=llama-3.1-8b-instant

# Idioma da transcrição (código de duas letras ISO 639-1)
LANGUAGE=pt

# Ativa ou desativa a etapa de limpeza de hesitações com Llama
ENABLE_CLEANUP=false

# Tecla de atalho global para iniciar/parar a gravação (teclas do pynput.keyboard.Key)
# Exemplos: f8, space, ctrl, cmd, shift, alt
HOTKEY=f8

# Taxa de amostragem do áudio gravado (em Hz)
SAMPLE_RATE=16000

# Dev overrides (opcional — a config oficial fica em Configurações…/Keychain)
# PROVIDER=groq|openai|local
# OPENAI_API_KEY=
